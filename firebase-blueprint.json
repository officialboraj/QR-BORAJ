{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile photo URL" },
        "role": { "type": "string", "enum": ["admin", "user", "manager"], "description": "User's role" },
        "apiKeys": { "type": "array", "description": "List of generated API keys" },
        "thirdPartyKeys": { "type": "object", "description": "Third-party integration keys (PayU, Razorpay, etc.)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "QRCode": {
      "title": "QR Code",
      "description": "A QR code generated by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the QR code" },
        "ownerId": { "type": "string", "description": "UID of the user who owns this QR" },
        "type": { "type": "string", "enum": ["url", "wifi", "upi", "whatsapp", "email", "vcard", "location", "pdf", "app"], "description": "Type of QR code" },
        "content": { "type": "string", "description": "The data encoded in the QR code" },
        "title": { "type": "string", "description": "User-friendly title for the QR" },
        "style": { "type": "object", "description": "Styling options (colors, logo, shapes)" },
        "isDynamic": { "type": "boolean", "description": "Whether the QR is dynamic (can be edited)" },
        "redirectUrl": { "type": "string", "description": "The target URL for dynamic QRs" },
        "scanCount": { "type": "integer", "description": "Total number of scans" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "campaignId": { "type": "string", "description": "Optional campaign ID" }
      },
      "required": ["ownerId", "type", "content", "createdAt"]
    },
    "Scan": {
      "title": "Scan Event",
      "description": "A single scan event of a QR code.",
      "type": "object",
      "properties": {
        "qrId": { "type": "string", "description": "ID of the scanned QR code" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the scan occurred" },
        "ip": { "type": "string", "description": "IP address of the scanner" },
        "device": { "type": "string", "description": "Device type (mobile, desktop, tablet)" },
        "os": { "type": "string", "description": "Operating system" },
        "browser": { "type": "string", "description": "Browser used" },
        "country": { "type": "string", "description": "Country of the scanner" },
        "city": { "type": "string", "description": "City of the scanner" },
        "referrer": { "type": "string", "description": "Referrer URL" }
      },
      "required": ["qrId", "timestamp"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "A marketing campaign grouping multiple QR codes.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the campaign" },
        "ownerId": { "type": "string", "description": "UID of the user who owns this campaign" },
        "name": { "type": "string", "description": "Campaign name" },
        "description": { "type": "string", "description": "Campaign description" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["ownerId", "name", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "User subscription details.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string", "enum": ["free", "pro", "enterprise"] },
        "status": { "type": "string", "enum": ["active", "pending", "expired"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "trialUsed": { "type": "boolean" }
      },
      "required": ["userId", "planId", "status"]
    },
    "PromoCode": {
      "title": "Promo Code",
      "description": "Flash offers and discounts.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discount": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["code", "discount", "isActive"]
    },
    "OTP": {
      "title": "OTP",
      "description": "Temporary one-time passwords for email verification.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "code": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "code", "expiresAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/qrcodes/{qrId}": { "schema": "QRCode", "description": "QR code definitions" },
    "/scans/{scanId}": { "schema": "Scan", "description": "Individual scan events" },
    "/campaigns/{campaignId}": { "schema": "Campaign", "description": "Marketing campaigns" },
    "/subscriptions/{subId}": { "schema": "Subscription", "description": "User subscriptions" },
    "/promocodes/{promoId}": { "schema": "PromoCode", "description": "Promo codes" },
    "/otps/{otpId}": { "schema": "OTP", "description": "Stored OTPs" }
  }
}
